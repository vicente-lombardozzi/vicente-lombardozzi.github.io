birth rate=
	0.2
	~	
	~		|

births coyotes=
	coyote birth rate*coyotes*roadrunners
	~	
	~		|

births roadrunners=
	birth rate*roadrunners
	~	
	~		|

coyote birth rate=
	0.00015
	~	
	~		|

coyote death rate=
	0.15
	~	
	~		|

coyotes= INTEG (
	births coyotes-deaths coyotes,
		initial coyotes)
	~	
	~		|

death rate=
	0.002
	~	
	~		|

death roadrunners=
	roadrunners*coyotes*(death rate)
	~	
	~		|

deaths coyotes=
	coyote death rate*coyotes
	~	
	~		|

initial coyotes=
	60
	~	
	~		|

roadrunners= INTEG (
	births roadrunners-death roadrunners,
		1000)
	~	
	~		|

