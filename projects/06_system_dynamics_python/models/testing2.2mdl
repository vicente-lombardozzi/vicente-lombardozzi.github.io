{UTF-8}
wealth extraction=
	MIN(extraction rate,Policy 1 Implementation)-subsistence requirement+immigration incentives
	~	
	~		|

immigration incentives=
	1
	~	
	~		|

Inmigration restriction rate=
	1
	~	
	~		|

immigrants=
	MAX(migration rate*(wealth extraction-attractive wealth threshold)*(1-VILLAGE POPULATION\
		/maximum village size)*VILLAGE POPULATION
	, 0)*Policy 2 Inmigration control
	~	
	~		|

Policy 2 Inmigration control=
	Inmigration restriction rate*VILLAGE POPULATION/maximum village size
	~	
	~		|

Policy 1 Implementation=
	DELAY FIXED(2*(FOREST/maximum forest capacity)/policy limit to extraction, delay policy time\
		, FOREST/maximum forest capacity)
	~	Month
	~		|

delay policy time=
	24
	~	
	~	Units in months
	|

policy limit to extraction=
	1
	~	
	~	2 means the extraction has been limited to the half of business as usual, \
		4 means that its has limited 1/4, etc.
	|

extraction rate=
	2*(FOREST/maximum forest capacity)
	~	
	~		|

extraction=
	MIN(extraction rate,Policy 1 Implementation)*VILLAGE POPULATION
	~	
	~		|

extraction rate 0=
	2*(FOREST 0/maximum forest capacity 0)
	~	
	~		|

attractive wealth threshold 0=
	0.3
	~	
	~		|

FOREST 0= INTEG (
	growth 0-extraction 0,
		25000)
	~	 [0,50000]
	~		|

emigrants 0=
	MAX(migration rate 0*(attractive wealth threshold 0-wealth extraction 0)*(VILLAGERS 0\
		/maximum village size 0)*VILLAGERS 0,0)
	~	
	~		|

growth 0=
	growth rate factor 0*(maximum forest capacity 0-FOREST 0)*FOREST 0/maximum forest capacity 0
	~	
	~		|

extraction 0=
	extraction rate 0*VILLAGERS 0
	~	
	~		|

growth rate factor 0=
	0.005
	~	
	~		|

migration rate 0=
	0.1
	~	
	~		|

immigrants 0=
	MAX(migration rate 0*(wealth extraction 0-attractive wealth threshold 0)*(1-VILLAGERS 0\
		/maximum village size 0)*VILLAGERS 0, 0)
	~	
	~		|

subsistence requirement 0=
	0.15
	~	
	~		|

maximum forest capacity 0=
	50000
	~	
	~		|

VILLAGERS 0= INTEG (
	immigrants 0-emigrants 0
	,
		100)
	~	 [0,500]
	~		|

maximum village size 0=
	500
	~	
	~		|

wealth extraction 0=
	extraction rate 0-subsistence requirement 0
	~	
	~		|

attractive wealth threshold=
	0.3
	~	
	~		|

emigrants=
	MAX(migration rate*(attractive wealth threshold-wealth extraction)*(VILLAGE POPULATION\
		/maximum village size)*VILLAGE POPULATION,0)
	~	
	~		|

subsistence requirement=
	0.15
	~	
	~		|

growth=
	growth rate factor*(maximum forest capacity-FOREST)*FOREST/maximum forest capacity
	~	
	~		|

growth rate factor=
	0.005
	~	
	~		|

maximum village size=
	500
	~	
	~		|

migration rate=
	0.1
	~	
	~		|

VILLAGE POPULATION= INTEG (
	immigrants-emigrants,
		100)
	~	 [0,500]
	~		|

FOREST= INTEG (
	growth-extraction,
		25000)
	~	 [0,50000]
	~		|

maximum forest capacity=
	50000
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 600
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

